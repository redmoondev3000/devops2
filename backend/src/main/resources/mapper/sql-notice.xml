<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.cloud.mapper.NoticeMapper">
	<select id="noticeList" resultType="org.cloud.dto.NoticeDTO">
		<![CDATA[
			SELECT id, title, content, writer, reg_date, hit FROM noticex
		]]>
	</select>
	
	<insert id="noticeWrite" parameterType="org.cloud.dto.NoticeDTO">
		<![CDATA[
			INSERT INTO noticex(title, content, writer, reg_date, hit)
			VALUES(#{title}, #{content}, #{writer}, NOW(), 0)
		]]>
	</insert>
	
	<update id="updateHit" parameterType="int">
		<![CDATA[
			UPDATE
				noticex
			SET
				hit = hit + 1
			WHERE
				id = #{id}		
		]]>
	</update>
	
	<select id="noticeDetail" resultType="org.cloud.dto.NoticeDTO" parameterType="int">
		<![CDATA[
			SELECT * 
			FROM noticex 
			WHERE id = #{id}
		]]>
	</select>
	
	<update id="noticeUpdate" parameterType="org.cloud.dto.NoticeDTO">
		UPDATE
			noticex
		SET
			title = #{title},
			content = #{content},
			reg_date = NOW()
		WHERE
			id = #{id}		
	</update>
	
	<delete id="noticeDelete" parameterType="int">
		<![CDATA[
			DELETE
			FROM
				noticex
			WHERE
				id = #{id}	
		]]>
	</delete>
</mapper> 




 